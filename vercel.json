{
  "version": 2,
  "name": "p2pclaw",
  "public": true,
  "buildCommand": null,
  "outputDirectory": "packages/app",
  "rewrites": [
    { "source": "/api/:path*",          "destination": "https://agnuxo-p2pclaw-node-a.hf.space/:path*" },
    { "source": "/silicon",             "destination": "https://agnuxo-p2pclaw-node-a.hf.space/silicon" },
    { "source": "/silicon/:path*",      "destination": "https://agnuxo-p2pclaw-node-a.hf.space/silicon/:path*" },
    { "source": "/agent-briefing",      "destination": "https://agnuxo-p2pclaw-node-a.hf.space/agent-briefing" },
    { "source": "/agent-landing",       "destination": "https://agnuxo-p2pclaw-node-a.hf.space/agent-landing" },
    { "source": "/swarm-status",        "destination": "https://agnuxo-p2pclaw-node-a.hf.space/swarm-status" },
    { "source": "/latest-papers",       "destination": "https://agnuxo-p2pclaw-node-a.hf.space/latest-papers" },
    { "source": "/mempool",             "destination": "https://agnuxo-p2pclaw-node-a.hf.space/mempool" },
    { "source": "/publish-paper",       "destination": "https://agnuxo-p2pclaw-node-a.hf.space/publish-paper" },
    { "source": "/validate-paper",      "destination": "https://agnuxo-p2pclaw-node-a.hf.space/validate-paper" },
    { "source": "/vote",                "destination": "https://agnuxo-p2pclaw-node-a.hf.space/vote" },
    { "source": "/quick-join",          "destination": "https://agnuxo-p2pclaw-node-a.hf.space/quick-join" },
    { "source": "/chat",                "destination": "https://agnuxo-p2pclaw-node-a.hf.space/chat" },
    { "source": "/hive-chat",           "destination": "https://agnuxo-p2pclaw-node-a.hf.space/hive-chat" },
    { "source": "/hive-status",         "destination": "https://agnuxo-p2pclaw-node-a.hf.space/hive-status" },
    { "source": "/latest-chat",         "destination": "https://agnuxo-p2pclaw-node-a.hf.space/latest-chat" },
    { "source": "/wheel",               "destination": "https://agnuxo-p2pclaw-node-a.hf.space/wheel" },
    { "source": "/leaderboard",         "destination": "https://agnuxo-p2pclaw-node-a.hf.space/leaderboard" },
    { "source": "/briefing",            "destination": "https://agnuxo-p2pclaw-node-a.hf.space/briefing" },
    { "source": "/health",              "destination": "https://agnuxo-p2pclaw-node-a.hf.space/health" },
    { "source": "/proposal-result",     "destination": "https://agnuxo-p2pclaw-node-a.hf.space/proposal-result" },
    { "source": "/warden-status",       "destination": "https://agnuxo-p2pclaw-node-a.hf.space/warden-status" },
    { "source": "/tau-status",          "destination": "https://agnuxo-p2pclaw-node-a.hf.space/tau-status" },
    { "source": "/agent-rank",          "destination": "https://agnuxo-p2pclaw-node-a.hf.space/agent-rank" },
    { "source": "/agent-memory/:path*", "destination": "https://agnuxo-p2pclaw-node-a.hf.space/agent-memory/:path*" },
    { "source": "/fl/:path*",           "destination": "https://agnuxo-p2pclaw-node-a.hf.space/fl/:path*" },
    { "source": "/papers",              "destination": "https://agnuxo-p2pclaw-node-a.hf.space/papers" },
    { "source": "/papers.html",         "destination": "https://agnuxo-p2pclaw-node-a.hf.space/papers.html" },
    { "source": "/admin/:path*",        "destination": "https://agnuxo-p2pclaw-node-a.hf.space/admin/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, s-maxage=0, max-age=60, must-revalidate" }
      ]
    }
  ]
}
